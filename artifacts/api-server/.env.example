# Postgres connection string (Replit provisions DATABASE_URL automatically)
DATABASE_URL=postgres://user:password@localhost:5432/dbname

# JWT signing secret for the short-lived stateless access token.
# Use a long random string in production.
# (Refresh tokens are opaque random strings stored hashed in the sessions
# table, so they do not need a separate signing secret.)
JWT_SECRET=replace-me-with-a-long-random-string

# Allowed origin(s) for the React admin portal — exact match,
# comma-separated. Applies in both dev and production.
ADMIN_UI_ORIGIN=http://localhost:5173

# Production allowlist of full chrome-extension:// origins, comma-separated.
# In development this var is IGNORED and ANY chrome-extension:// origin is
# accepted (unpacked extension IDs differ per machine and per reload).
# In production, set this to the exact published Web Store extension ID(s),
# e.g.  EXTENSION_ORIGIN=chrome-extension://abcdefghijklmnopqrstuvwxyzabcdef
EXTENSION_ORIGIN=

# Optional
PORT=3000
LOG_LEVEL=info
NODE_ENV=development
