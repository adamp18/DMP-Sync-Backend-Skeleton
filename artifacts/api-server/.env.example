# Postgres connection string (Replit provisions DATABASE_URL automatically)
DATABASE_URL=postgres://user:password@localhost:5432/dbname

# JWT signing secret for the short-lived stateless access token.
# Use a long random string in production.
# (Refresh tokens are opaque random strings stored hashed in the sessions
# table, so they do not need a separate signing secret.)
JWT_SECRET=replace-me-with-a-long-random-string

# Allowed origin for the React admin portal (comma-separated for multiple)
ADMIN_UI_ORIGIN=http://localhost:5173

# Allowed origin prefix for the Chrome extension
EXTENSION_ORIGIN=chrome-extension://

# Optional
PORT=3000
LOG_LEVEL=info
NODE_ENV=development
